# =============================================================================
# Snowflake → Neo4j Security Demo — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ── Snowflake ──────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your-account.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=SECURITY_DEMO_DB
SNOWFLAKE_SCHEMA=DEMO_SCHEMA
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=DATA_ENGINEER

# ── Neo4j ──────────────────────────────────────────────────────────────────────
# Neo4j Aura Cloud
NEO4J_URI=neo4j+s://1c8c2b04.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_aura_password
